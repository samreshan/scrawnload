{
  "manifest_version": 3,
  "name": "Scrawnload",
  "version": "0.1.0",
  "description": "Detects video and audio files on the current page and lets you download them.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": ["downloads", "webRequest", "webNavigation", "tabs"],
  "host_permissions": ["<all_urls>"]
}
